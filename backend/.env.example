VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
MIDTRANS_SERVER_KEY=your-midtrans-server-key
VITE_MIDTRANS_CLIENT_KEY=your-midtrans-client-key
VITE_MIDTRANS_IS_PRODUCTION=false
VITE_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
PORT=3001
NODE_ENV=development

# ========== SPOTIFY INTEGRATION ==========
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:3001/api/spotify/callback

# Commission Settings (%)
SPOTIFY_COMMISSION_PERCENTAGE=15
SPOTIFY_ARTIST_PAYOUT_PERCENTAGE=85

# Spotify API Base URL (don't change)
SPOTIFY_API_BASE_URL=https://api.spotify.com/v1

# CRITICAL: Webhook Secret for Spotify webhook verification
# Generate a random strong string: openssl rand -hex 32
SPOTIFY_WEBHOOK_SECRET=your_secure_webhook_secret_here

# ========== SECURITY NOTES ==========
# 1. NEVER commit real .env files to git - they contain secrets
# 2. All .env files should be added to .gitignore (already configured)
# 3. For production, use environment variables in your deployment platform (Vercel, Railway, etc)
# 4. Rotate SPOTIFY_WEBHOOK_SECRET regularly
# 5. Use strong, randomly generated secrets (minimum 32 characters)
# 6. Keep SERVICE_ROLE_KEY secure - only use on backend
# 7. ANON_KEY can be used on frontend (it has limited permissions via RLS)

