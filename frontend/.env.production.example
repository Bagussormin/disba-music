# ⚠️ RENAME THIS FILE TO .env.production BEFORE DEPLOYING TO PRODUCTION
# Copy this file to .env.production and fill in your actual credentials

# ===== API CONFIGURATION =====
# Update this to match your backend deployment URL
VITE_API_URL=https://your-backend-domain.com

# ===== SUPABASE (Get from https://app.supabase.com) =====
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ===== MIDTRANS (Get from https://midtrans.com) =====
# Use Sandbox first, then switch to Production credentials
VITE_MIDTRANS_CLIENT_KEY=your-sandbox-client-key-here
VITE_MIDTRANS_IS_PRODUCTION=false
